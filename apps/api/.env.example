# Variáveis de ambiente da API Finly
# Copie este arquivo para .env e preencha os valores antes de rodar localmente.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).
#
# Padrão .NET: __ separa seções de configuração (equivale a : no appsettings.json)
# Exemplo: JWT__SecretKey sobrescreve Jwt:SecretKey do appsettings.json

# JWT — gere uma chave aleatória com: openssl rand -base64 32
JWT__SecretKey=
JWT__Issuer=Finly.Api
JWT__Audience=Finly.Web

# Banco de dados
ConnectionStrings__DefaultConnection=
