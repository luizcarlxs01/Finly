# Variáveis de ambiente para o Docker Compose local
# Copie este arquivo para docker/.env e preencha os valores antes de rodar.
# O arquivo .env NUNCA deve ser commitado (já está no .gitignore).

# Senha do SQL Server — deve ter letras maiúsculas, minúsculas, números e símbolo
SA_PASSWORD=SuaSenhaForte@123

# Chave JWT — gere com: openssl rand -base64 32
JWT__SecretKey=
